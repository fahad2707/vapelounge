# Copy to `.env.local` for development or set in Vercel → Project → Settings → Environment Variables.

# MongoDB Atlas (or any MongoDB 4.2+ deployment)
# Example: mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=

# Optional — database name (default: vapelounge)
MONGODB_DB_NAME=vapelounge
